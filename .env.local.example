# ── Google OAuth ──────────────────────────────────────────────
# Merr nga: https://console.cloud.google.com → APIs → Credentials
# Authorized redirect URIs: https://your-app.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── NextAuth ───────────────────────────────────────────────────
# Gjenero me: openssl rand -base64 32
AUTH_SECRET=replace_with_random_secret_32_chars_min

# ── Vercel Blob (për ruajtje JSON në Vercel) ───────────────────
# Merr nga: Vercel Dashboard → Storage → Blob → Create Store
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxx

# ── URL (NextAuth v5 — vetëm për development lokal) ───────────
# Në Vercel nuk nevojitet — detektohet automatikisht
# AUTH_URL=http://localhost:3000
